<div class="mb-4">
  <%= link_to "&larr; Projects".html_safe, projects_path, class: "text-sm text-gray-500 hover:text-white" %>
</div>

<h1 class="text-2xl font-bold mb-1"><%= @project.display_name %></h1>
<p class="text-sm text-gray-500 mb-6"><%= @project.path %> &middot; <%= @project.source_type.titleize %></p>

<div class="space-y-2">
  <% @sessions.each do |session| %>
    <%= link_to session_path(session), class: "block bg-gray-900 border border-gray-800 rounded-lg p-4 hover:border-gray-600 transition" do %>
      <div class="flex items-start justify-between gap-4">
        <div class="min-w-0 flex-1">
          <div class="text-sm text-white truncate"><%= session.display_title %></div>
          <div class="text-xs text-gray-500 mt-1">
            <%= session.messages_count %> messages
            <% if session.model.present? %>
              &middot; <%= session.model %>
            <% end %>
          </div>
        </div>
        <div class="text-xs text-gray-500 whitespace-nowrap">
          <%= session.started_at&.strftime("%b %d, %Y %H:%M") %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>

<% total = @project.sessions_count %>
<% page = (params[:page] || 1).to_i %>
<% if total > 30 %>
  <div class="flex gap-4 mt-6 text-sm">
    <% if page > 1 %>
      <%= link_to "Previous", project_path(@project, page: page - 1), class: "text-gray-400 hover:text-white" %>
    <% end %>
    <% if page * 30 < total %>
      <%= link_to "Next", project_path(@project, page: page + 1), class: "text-gray-400 hover:text-white" %>
    <% end %>
  </div>
<% end %>
