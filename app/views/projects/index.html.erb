<% content_for(:title, "Projects — Recall") %>
<h1>Projects</h1>

<div data-controller="search" data-search-url-value="<%= projects_path %>">
  <form action="<%= projects_path %>" method="get">
    <div class="search-form">
      <input type="text" name="q" value="<%= @query %>" placeholder="Search across all conversations..."
             class="search-input" autofocus
             data-search-target="input"
             data-action="input->search#search">
      <button type="submit" class="search-btn">Search</button>
    </div>
  </form>

  <div data-search-target="results">
    <% if @query.present? && @results %>
      <%= render partial: "projects/search_results" %>
    <% end %>
  </div>
</div>

<% unless @query.present? %>
  <div class="grid-projects">
    <% @projects.each do |project| %>
      <%= link_to project_path(project), class: "card" do %>
        <div class="project-card-name"><%= project.display_name %></div>
        <div class="project-card-path"><%= project.path %></div>
        <div class="project-card-footer">
          <span class="project-card-sessions"><strong><%= project.sessions_count %></strong> sessions</span>
          <% (project.try(:source_types_csv)&.split(",") || project.source_types).each do |st| %>
            <span class="source-badge source-badge-<%= st == 'claude_code' ? 'claude' : 'codex' %>">
              <%= st.titleize %>
            </span>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
