<h1>Projects</h1>

<% %w[claude_code codex].each do |source_type| %>
  <% projects = @projects_by_source[source_type] %>
  <% next unless projects&.any? %>

  <h2><%= source_type.titleize %></h2>
  <div class="grid-projects">
    <% projects.each do |project| %>
      <%= link_to project_path(project), class: "card" do %>
        <div class="text-white" style="font-weight:500"><%= project.display_name %></div>
        <div class="text-xs text-muted mt-1 truncate"><%= project.path %></div>
        <div class="text-xs text-muted" style="margin-top:0.5rem"><%= project.sessions_count %> sessions</div>
      <% end %>
    <% end %>
  </div>
<% end %>
