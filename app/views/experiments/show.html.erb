<%= turbo_stream_from @experiment %>

<%= link_to "&larr; Experiments".html_safe, experiments_path, class: "back-link" %>

<div class="experiment-header">
  <div class="experiment-title-row">
    <h1 class="page-title"><%= @experiment.name %></h1>
    <% if @experiment.session %>
      <%= link_to session_path(@experiment.session), class: "btn btn-ghost btn-sm" do %>
        Session: <%= @experiment.session.display_title.truncate(40) %>
      <% end %>
    <% end %>
    <div id="experiment_status">
      <%= render "experiments/status", experiment: @experiment %>
    </div>
    <%= button_to experiment_path(@experiment), method: :delete, class: "btn btn-ghost btn-sm", title: "Delete experiment", data: { turbo_confirm: "Delete this experiment and all its runs?" } do %>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/></svg>
    <% end %>
  </div>

  <% if @experiment.system_prompt.present? %>
    <details class="experiment-system-prompt">
      <summary class="text-muted text-sm">System prompt</summary>
      <pre class="experiment-prompt-text"><%= @experiment.system_prompt %></pre>
    </details>
  <% end %>

  <details class="experiment-prompt-details" open>
    <summary class="text-muted text-sm">Prompt</summary>
    <pre class="experiment-prompt-text"><%= @experiment.prompt_text %></pre>
  </details>
</div>

<div class="experiment-run-models">
  <%= form_with url: run_model_experiment_path(@experiment), method: :post, class: "run-models-form" do %>
    <% existing_keys = @experiment.runs.pluck(:provider_key) %>
    <% LLM.provider_groups.each do |group_name, keys| %>
      <div class="provider-group">
        <span class="provider-group-label"><%= group_name %> <span class="provider-group-hint">&mdash; <%= LLM::TIER_HINTS[group_name] %></span></span>
        <div class="provider-checkbox-grid">
          <% keys.each do |key| %>
            <label class="provider-checkbox-card <%= 'already-run' if existing_keys.include?(key) %>">
              <input type="checkbox" name="provider_keys[]" value="<%= key %>">
              <span class="provider-checkbox-name"><%= key.sub(/\A[^:]+:/, "") %></span>
            </label>
          <% end %>
        </div>
      </div>
    <% end %>
    <button type="submit" class="btn btn-primary btn-sm">Run Selected</button>
  <% end %>
</div>

<div class="runs-grid">
  <% @experiment.runs.order(:created_at).each do |run| %>
    <%= render "experiments/run", run: run %>
  <% end %>
</div>

<% if @experiment.runs.completed.count > 1 %>
  <div class="experiment-comparison-summary">
    <h2>Comparison</h2>
    <table class="comparison-table">
      <thead>
        <tr>
          <th>Provider</th>
          <th>Model</th>
          <th>Duration</th>
          <th>Tokens In</th>
          <th>Tokens Out</th>
          <th>Cost</th>
          <th>Response Length</th>
        </tr>
      </thead>
      <tbody>
        <% @experiment.runs.completed.order(:duration_ms).each do |run| %>
          <tr>
            <td><%= run.provider_key %></td>
            <td class="text-xs"><%= run.model %></td>
            <td><%= run.duration_formatted %></td>
            <td><%= number_with_delimiter(run.tokens_in) %></td>
            <td><%= number_with_delimiter(run.tokens_out) %></td>
            <td><%= run.cost_formatted || "free" %></td>
            <td><%= number_with_delimiter(run.response_text&.length || 0) %> chars</td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>
