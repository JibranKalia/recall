<div id="run_<%= run.id %>" class="run-card run-status-<%= run.status %>">
  <%= button_to destroy_run_experiment_path(run.experiment, run_id: run.id), method: :delete, class: "run-delete-btn", data: { turbo_confirm: "Delete this run?" }, title: "Delete run" do %>
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/><line x1="10" y1="11" x2="10" y2="17"/><line x1="14" y1="11" x2="14" y2="17"/></svg>
  <% end %>

  <div class="run-card-header">
    <span class="run-provider-name"><%= run.provider_key %></span>
    <span class="run-model-tag"><%= run.model %></span>
    <span class="experiment-status-badge experiment-status-<%= run.status %>"><%= run.status %></span>
  </div>

  <% if run.completed? %>
    <div class="run-metrics">
      <span class="run-metric">
        <span class="run-metric-label">Time</span>
        <span class="run-metric-value"><%= run.duration_formatted %></span>
      </span>
      <span class="run-metric">
        <span class="run-metric-label">Tokens</span>
        <span class="run-metric-value"><%= number_with_delimiter(run.tokens_in) %> / <%= number_with_delimiter(run.tokens_out) %></span>
      </span>
      <span class="run-metric">
        <span class="run-metric-label">Cost</span>
        <span class="run-metric-value"><%= run.cost_formatted || "free" %></span>
      </span>
    </div>
    <div class="run-response prose"><%= render_markdown(run.response_text || "") %></div>
  <% elsif run.failed? %>
    <div class="run-error"><%= run.error_message %></div>
  <% else %>
    <div class="run-pending">
      <div class="run-spinner"></div>
      <span><%= run.status == "running" ? "Running..." : "Queued" %></span>
    </div>
  <% end %>

  <div class="run-card-actions">
    <%= button_to "Re-run", rerun_experiment_path(run.experiment, run_id: run.id), method: :post, class: "btn btn-secondary btn-xs" %>
  </div>
</div>
