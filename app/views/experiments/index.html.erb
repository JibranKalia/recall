<% content_for(:title, "Experiments — Recall") %>
<div data-controller="experiments-toggle">
<div class="page-header-row">
  <div>
    <h1 class="page-title">Experiments</h1>
    <p class="page-subtitle">Compare LLM providers side-by-side
      <% if params[:session_id].present? %>
        <span class="text-dim text-xs">— filtered · <%= link_to "clear", experiments_path %></span>
      <% end %>
    </p>
  </div>
  <div class="page-header-actions">
    <button class="btn btn-ghost btn-sm" data-experiments-toggle-target="toggleBtn" data-action="experiments-toggle#toggle">Collapse all</button>
    <%= link_to "New Experiment", new_experiment_path, class: "btn btn-primary" %>
  </div>
</div>

<% if @grouped.any? %>
  <div class="experiment-sessions-list">
    <% @grouped.each do |session, experiments| %>
      <details class="experiment-session-group" open data-experiments-toggle-target="group">
        <summary class="experiment-session-summary">
          <span class="experiment-session-title">
            <%= session.display_title.truncate(80) %>
            <%= link_to experiments_path(session_id: session.id), class: "experiment-session-filter", title: "Filter to this session" do %>
              <%= icon_tag(:filter) %>
            <% end %>
          </span>
          <span class="experiment-session-meta">
            <span class="experiment-session-count"><%= experiments.size %> experiments</span>
            <span class="text-dim text-xs"><%= time_ago_in_words(experiments.first.created_at) %> ago</span>
          </span>
        </summary>
        <div class="experiments-list">
          <% experiments.each do |experiment| %>
            <div class="experiment-card-wrapper">
              <%= link_to experiment_path(experiment), class: "card experiment-card" do %>
                <div class="experiment-card-header">
                  <span class="experiment-card-name"><%= experiment.name %></span>
                  <span class="experiment-status-badge experiment-status-<%= experiment.status %>"><%= experiment.status %></span>
                </div>
                <div class="experiment-card-prompt"><%= experiment.prompt_text.truncate(120) %></div>
                <div class="experiment-card-footer">
                  <span class="text-dim text-xs"><%= experiment.runs.size %> runs</span>
                  <span class="text-dim text-xs"><%= time_ago_in_words(experiment.created_at) %> ago</span>
                </div>
              <% end %>
              <%= button_to experiment_path(experiment), method: :delete, class: "experiment-delete-btn", title: "Delete experiment", data: { turbo_confirm: "Delete this experiment?" } do %>
                <%= icon_tag(:trash) %>
              <% end %>
            </div>
          <% end %>
        </div>
      </details>
    <% end %>
  </div>
<% else %>
  <p class="text-muted">No experiments yet. <%= link_to "Create one", new_experiment_path %>.</p>
<% end %>
</div>
