<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Recall" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag "base", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "nav", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "cards", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "sessions", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "search", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "messages", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "prose", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "syntax", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "experiments", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <%= turbo_stream_from "imports" %>
    <nav class="nav">
      <%= link_to "Recall", root_path, class: "nav-brand" %>
      <div class="nav-links">
        <%= link_to "Projects", projects_path, class: "nav-link" %>
        <%= link_to "Search", search_path, class: "nav-link" %>
        <%= link_to "Experiments", experiments_path, class: "nav-link" %>
      </div>
      <span class="nav-stats" id="nav_stats"><%= Session.count %> sessions &middot; <%= Message.count %> messages</span>
      <%= render "imports/button" %>
    </nav>
    <main class="container">
      <%= yield %>
    </main>
  </body>
</html>
