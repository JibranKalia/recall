<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Recall" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-gray-950 text-gray-100 min-h-screen">
    <nav class="bg-gray-900 border-b border-gray-800 px-6 py-3 flex items-center gap-6">
      <%= link_to "Recall", root_path, class: "text-lg font-bold text-white" %>
      <%= link_to "Projects", projects_path, class: "text-gray-400 hover:text-white text-sm" %>
      <%= link_to "Search", search_path, class: "text-gray-400 hover:text-white text-sm" %>
      <span class="ml-auto text-gray-600 text-xs"><%= Session.count %> sessions / <%= Message.count %> messages</span>
    </nav>
    <main class="max-w-5xl mx-auto px-4 py-6">
      <%= yield %>
    </main>
  </body>
</html>
