<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Recall" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <link rel="icon" href="/favicon.svg" type="image/svg+xml">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "messages", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "prose", "data-turbo-track": "reload" %>
    <%= stylesheet_link_tag "syntax", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body>
    <nav class="nav">
      <%= link_to "Recall", root_path, class: "nav-brand" %>
      <div class="nav-links">
        <%= link_to "Projects", projects_path, class: "nav-link" %>
        <%= link_to "Search", search_path, class: "nav-link" %>
      </div>
      <span class="nav-stats"><span><%= Session.count %></span> sessions &middot; <span><%= Message.count %></span> messages</span>
    </nav>
    <main class="container">
      <%= yield %>
    </main>
  </body>
</html>
