<div class="mb-4">
  <%= link_to "&larr; #{@session.project.display_name}".html_safe, project_path(@session.project), class: "text-sm text-gray-500 hover:text-white" %>
</div>

<div class="mb-6">
  <h1 class="text-xl font-bold mb-1"><%= @session.display_title %></h1>
  <div class="text-xs text-gray-500 flex flex-wrap gap-3">
    <span><%= @session.source_name %></span>
    <span><%= @session.started_at&.strftime("%b %d, %Y %H:%M") %></span>
    <% if @session.model.present? %>
      <span><%= @session.model %></span>
    <% end %>
    <span><%= @session.messages_count %> messages</span>
    <% if @session.total_tokens > 0 %>
      <span><%= number_with_delimiter(@session.total_tokens) %> tokens</span>
    <% end %>
  </div>
</div>

<div class="space-y-4">
  <% @messages.each do |message| %>
    <div id="msg-<%= message.id %>" class="rounded-lg p-4 <%= message_bg_class(message.role) %>">
      <div class="flex items-center gap-2 mb-2">
        <span class="text-xs font-semibold <%= message_role_class(message.role) %>"><%= message.role %></span>
        <span class="text-xs text-gray-600"><%= message.timestamp&.strftime("%H:%M:%S") %></span>
        <% if message.model.present? %>
          <span class="text-xs text-gray-600"><%= message.model %></span>
        <% end %>
      </div>

      <% if message.role == "assistant" %>
        <%= render_assistant_content(message) %>
      <% else %>
        <div class="text-sm text-gray-200 whitespace-pre-wrap break-words"><%= message.content_text %></div>
      <% end %>
    </div>
  <% end %>
</div>
