<div data-controller="sticky-header">
  <div class="session-header" data-sticky-header-target="header">
    <%= link_to project_path(@session.project), class: "back-link" do %>
      <span class="back-arrow">&larr;</span> <%= @session.project.display_name %>
    <% end %>

    <div class="session-title-row">
      <h1 class="session-title"><%= @session.display_title %></h1>
      <form action="<%= regenerate_title_session_path(@session) %>" method="post" data-controller="pending-btn" data-action="submit->pending-btn#submit">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <button type="submit" class="regenerate-title-btn" data-pending-btn-target="btn" title="Regenerate title">↻</button>
      </form>
    </div>

    <div class="session-meta">
      <span class="session-meta-tag session-meta-tag--source"><%= @session.source_name %></span>
      <span class="session-meta-tag"><%= @session.started_at&.strftime("%b %d, %Y &middot; %H:%M").html_safe %></span>
      <% if @session.model.present? %>
        <span class="session-meta-tag session-meta-tag--model"><%= @session.model %></span>
      <% end %>
      <span class="session-meta-tag"><%= @session.messages_count %> messages</span>
      <% if @session.total_tokens > 0 %>
        <span class="session-meta-tag"><%= number_with_delimiter(@session.total_tokens) %> tokens</span>
      <% end %>
    </div>

    <% if @session.summary.present? %>
      <div class="session-summary prose"><%= render_markdown @session.summary %></div>
    <% end %>
  </div>

  <div class="session-actions-row">
    <div class="session-resume-bar" data-controller="clipboard">
      <span class="resume-prompt">$</span>
      <code class="resume-command" data-clipboard-target="source"><%= resume_command(@session) %></code>
      <button class="resume-copy-btn" data-action="click->clipboard#copy" data-clipboard-target="button" title="Copy resume command">
        <span data-clipboard-target="label">Copy</span>
      </button>
    </div>
    <div class="copy-markdown-wrapper" data-controller="copy-markdown" data-copy-markdown-url-value="<%= markdown_session_path(@session) %>" data-action="click@window->copy-markdown#close">
      <button class="session-action-btn" data-action="click->copy-markdown#toggle" title="Copy session as Markdown">
        <span data-copy-markdown-target="label">Copy as Markdown</span>
      </button>
      <div class="copy-markdown-menu hidden" data-copy-markdown-target="menu">
        <button class="copy-markdown-option" data-action="click->copy-markdown#copy" data-copy-markdown-thinking-param="false" data-copy-markdown-tool-details-param="false">Conversation only</button>
        <button class="copy-markdown-option" data-action="click->copy-markdown#copy" data-copy-markdown-thinking-param="false" data-copy-markdown-tool-details-param="true">+ Tool I/O</button>
        <button class="copy-markdown-option" data-action="click->copy-markdown#copy" data-copy-markdown-thinking-param="true" data-copy-markdown-tool-details-param="true">+ Tool I/O + Thinking</button>
      </div>
    </div>
  </div>

  <div class="session-sticky-bar" data-sticky-header-target="stickyBar">
    <div class="sticky-bar-title hidden" data-sticky-header-target="stickyTitle">
      <%= link_to project_path(@session.project), class: "sticky-bar-back", title: @session.project.display_name do %>
        &larr;
      <% end %>
      <span class="sticky-bar-name"><%= @session.display_title %></span>
    </div>
  </div>
</div>

<div class="message-list" data-controller="code-copy">
  <% @messages.each do |message| %>
    <div id="msg-<%= message.id %>" class="message <%= message_css_class(message) %>">
      <% if message.role == "user" %>
        <div class="message-header">
          <span class="message-role-label role-label-user">You</span>
          <span class="message-timestamp"><%= message.timestamp&.strftime("%H:%M:%S") %></span>
        </div>
      <% elsif message.role == "assistant" && assistant_has_text?(message) %>
        <div class="message-header">
          <span class="message-role-label role-label-assistant">Assistant</span>
          <span class="message-timestamp"><%= message.timestamp&.strftime("%H:%M:%S") %></span>
          <% if message.model.present? %>
            <span class="message-model-tag message-model-right"><%= message.model %></span>
          <% end %>
        </div>
      <% end %>

      <%= render_message_content(message) %>
    </div>
  <% end %>
</div>

<button class="jump-bottom-btn" data-controller="scroll-bottom" data-action="click->scroll-bottom#scroll" title="Jump to bottom">
  &#8595;
</button>
