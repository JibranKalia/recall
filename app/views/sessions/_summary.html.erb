<% summary = session.latest_summary %>
<% if summary %>
  <div class="session-summary-wrapper" data-controller="message-copy" data-message-copy-raw-value="<%= summary.body %>">
    <div class="session-summary prose" data-message-copy-target="content"><%= render_markdown summary.body %></div>
    <div class="session-summary-meta">
      <span class="summary-timestamp">Summarized <%= time_ago_in_words(summary.created_at) %> ago &middot; <%= summary.created_at.strftime("%b %d, %Y %H:%M") %><% if summary.experiment_run %> &middot; <%= link_to summary.model, experiment_path(summary.experiment_run.experiment) %><% end %></span>
      <button class="msg-copy-btn summary-copy-btn" data-action="click->message-copy#copy" title="Copy summary">
        <%= icon_tag(:copy, data: { message_copy_target: "icon" }) %>
      </button>
    </div>
  </div>
<% end %>
