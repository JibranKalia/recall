<% summary = session.latest_summary %>
<% if summary %>
  <div class="session-summary-wrapper" data-controller="message-copy" data-message-copy-raw-value="<%= summary.body %>">
    <div class="session-summary prose" data-message-copy-target="content"><%= render_markdown summary.body %></div>
    <div class="session-summary-meta">
      <span class="summary-timestamp">Summarized <%= time_ago_in_words(summary.created_at) %> ago &middot; <%= summary.created_at.strftime("%b %d, %Y %H:%M") %></span>
      <button class="msg-copy-btn summary-copy-btn" data-action="click->message-copy#copy" title="Copy summary">
        <span data-message-copy-target="icon"><svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="5.5" y="5.5" width="8" height="8" rx="1.5"/><path d="M10.5 5.5V3a1.5 1.5 0 0 0-1.5-1.5H3A1.5 1.5 0 0 0 1.5 3v6A1.5 1.5 0 0 0 3 10.5h2.5"/></svg></span>
      </button>
    </div>
  </div>
<% end %>
