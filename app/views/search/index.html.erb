<h1>Search</h1>

<%= form_tag search_path, method: :get do %>
  <div class="search-form">
    <input type="text" name="q" value="<%= @query %>" placeholder="Search conversations..."
           class="search-input" autofocus>
    <button type="submit" class="search-btn">Search</button>
  </div>
<% end %>

<% if @query.present? && @results %>
  <p class="text-sm text-muted mb-4"><%= @results.size %> result(s) for "<%= @query %>"</p>

  <div class="session-list">
    <% @results.each do |message| %>
      <% session = @sessions_by_id[message.session_id] %>
      <% next unless session %>

      <%= link_to session_path(session, anchor: "msg-#{message.id}"), class: "card" do %>
        <div class="search-result-meta">
          <span class="search-result-source"><%= session.source_name %></span>
          <span><%= session.project&.display_name %></span>
          <span><%= session.started_at&.strftime("%b %d, %Y") %></span>
          <span class="search-result-badge"><%= message.role %></span>
        </div>
        <div class="search-result-snippet">
          <% if message.respond_to?(:snippet) && message.snippet.present? %>
            <%= sanitize message.snippet, tags: %w[mark] %>
          <% else %>
            <%= message.content_text&.truncate(200) %>
          <% end %>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>
